SUBMISSIONS.md


# Plan + experiment artifacts (ledger persists locally)
ledger/
papers/

# Experiments: ignore everything inside by default, but re-include the
# official evolutionary iteration dirs so spec + run.py + manifest travel
# through git to the cluster (no more inline-JSON sbatch --wrap).
# Cluster outputs (result.json, trace.jsonl, checkpoints) stay ignored.
experiments/*
!experiments/iter_*/
!experiments/champion_eval/
!experiments/submission_*/
# Canonical workflow: experiment artifacts travel ONLY via git push/pull.
# Cluster commits result.json + trace.jsonl back; Mac pulls; Claude reads
# locally. NO terminal forensics, NO paste-text-into-chat (ANTIPATTERN 11a).
# Only heavy weights (checkpoints/) stay out of git.
experiments/iter_*/**/checkpoints/
experiments/champion_eval/**/checkpoints/
# Per-seed scratch dirs from ai4pain.multiseed (n_seeds>1). Each seed trains
# into its own _seed_N/ dir; only the aggregated child_NN/result.json is the
# canonical artifact the loop reads. The per-seed dirs are debug-only bloat.
experiments/iter_*/**/_seed_*/
experiments/champion_eval/**/_seed_*/

